{
  "name": "your-everyday-tools-desktop",
  "version": "1.3.0",
  "description": "Your Everyday Tools — 100+ offline utilities in a desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "author": "Your Everyday Tools",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.youreverydaytools.desktop",
    "productName": "Your Everyday Tools",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/backend/",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../images/icon.ico",
      "sign": "./sign.js"
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "../images/icon.ico",
      "include": "installer.nsh",
      "warningsAsErrors": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "rachmad-jenss",
        "repo": "your-everyday-tools-desktop"
      }
    ],
    "releaseInfo": {
      "releaseNotes": "Versi baru v1.3.0 — sync upstream Flask v0.6.3 + v0.6.4\n\nYang baru:\n• Merge Images — gabung beberapa gambar\n• Theme switcher — system / light / dark\n• Tool search + global search di top bar\n• Conversion fidelity layer — banner kualitas konversi\n• Bootstrap Icons vendored (UI offline)\n\nPerbaikan:\n• Konversi dokumen, gambar, media, dan CAD lebih akurat"
    },
    "mac": {
      "target": "dmg",
      "icon": "../images/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
